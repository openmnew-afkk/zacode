# ===== TeleCinema — переменные окружения (опционально) =====
# Каталог работает сразу без токенов — используется OMDb API с бесплатным ключом.

# (Опционально) переопределить ключ OMDb API
# OMDB_API_KEY=ваш_ключ

# (Опционально) базовый URL API. На проде — пусто.
# VITE_API_BASE=http://localhost:5173
