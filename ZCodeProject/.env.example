# ===== TeleCinema — переменные окружения =====
# Скопируйте в .env / .env.local и заполните при необходимости.

# Токен VideoCDN (СЕРВЕРНЫЙ — читается serverless-функциями Vercel, НЕ попадает в клиентский бандл).
# Получить токен: https://videocdn.tv → Личный кабинет / API
# Если задан здесь — токен в приложении (Профиль → Источники) вводить НЕ обязательно.
VIDEOCDN_TOKEN=

# (Опционально) базовый URL вашего API. На проде оставьте пустым — используются относительные пути /api.
# Удобно при локальной разработке, если бэкенд крутится отдельно:
# VITE_API_BASE=http://localhost:3000
